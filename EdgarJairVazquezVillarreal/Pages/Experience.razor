@page "/experience"
@inject EdgarJairVazquezVillarreal.Services.LanguageService LangApp
@implements IDisposable

<PageTitle>@LangApp.Get("NavExperience")</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h2 class="fw-bold">@LangApp.Get("NavExperience")</h2>
            <p class="text-secondary">@LangApp.Get("ExpSubtitle")</p>
            <a href="ImagenesDocs/CVEdgarJairVazquezVillarreal.pdf"
               class="btn btn-outline-primary mt-2" target="_blank">
                <i class="bi bi-file-earmark-person me-2"></i>@LangApp.Get("DownloadCVFull")
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-10 offset-md-1">
            <div class="timeline-section">

                <!-- ── Puesto 1: Julian Electric ─────────────────── -->
                <div class="timeline-item mb-5">
                    <div class="row">
                        <div class="col-md-3 text-md-end">
                            <h5 class="fw-bold mb-1">2025</h5>
                            <span class="badge bg-secondary">@LangApp.Get("Exp1Status")</span>
                        </div>
                        <div class="col-md-9 timeline-connector ps-4 position-relative">
                            <div class="timeline-dot active"></div>
                            <h4>@LangApp.Get("Exp1Title")</h4>
                            <h6 class="fst-italic mb-3">@LangApp.Get("Exp1Company")</h6>
                            <p>@LangApp.Get("Exp1Intro")</p>
                            <ul class="mb-3">
                                <li>@LangApp.Get("Exp1B1")</li>
                                <li>@LangApp.Get("Exp1B2")</li>
                                <li>@LangApp.Get("Exp1B3")</li>
                                <li>@LangApp.Get("Exp1B4")</li>
                                <li>@LangApp.Get("Exp1B5")</li>
                                <li>@LangApp.Get("Exp1B6")</li>
                                <li>@LangApp.Get("Exp1B7")</li>
                            </ul>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge badge-glass">C# .NET</span>
                                <span class="badge badge-glass">SQL Server</span>
                                <span class="badge badge-glass">ESP32</span>
                                <span class="badge badge-glass">PLC Allen-Bradley</span>
                                <span class="badge badge-glass">Lean Six Sigma</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- /timeline-section -->
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        LangApp.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        LangApp.OnLanguageChanged -= StateHasChanged;
    }
}
