@page "/"
@inject EdgarJairVazquezVillarreal.Services.LanguageService LangApp
@implements IDisposable

<PageTitle>@LangApp.Get("HomeTitle")</PageTitle>

<h1>@LangApp.Get("HomeTitle")</h1>

<div class="row">
    <div class="col-md-8">
        <p>@LangApp.Get("BioP1")</p>
        <p>@LangApp.Get("BioP2")</p>
        <p>@LangApp.Get("BioP3")</p>
        <p>@LangApp.Get("BioP4")</p>
    </div>
    <div class="col-md-4">
        <div class="text-center">
            <a href="ImagenesDocs/CVEdgarJairVazquezVillarreal.pdf"
               class="btn btn-primary w-100" target="_blank">
                <i class="bi bi-file-earmark-pdf-fill me-2"></i>@LangApp.Get("DownloadCV")
            </a>
        </div>
    </div>
</div>

<!-- Tarjetas de habilidades -->
<div class="row mt-4">
    <div class="col-md-4 mb-4">
        <div class="glass-card scroll-reveal h-100 p-4">
            <h3 class="mb-3 text-neon">
                <i class="bi bi-gear me-2"></i>@LangApp.Get("MechatronicsTitle")
            </h3>
            <ul class="tech-list">
                <li>@LangApp.Get("Solidworks")</li>
                <li>@LangApp.Get("PLC")</li>
                <li>@LangApp.Get("PCB")</li>
                <li>@LangApp.Get("Labview")</li>
            </ul>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="glass-card scroll-reveal h-100 p-4">
            <h3 class="mb-3 text-neon">
                <i class="bi bi-code-slash me-2"></i>@LangApp.Get("SoftwareTitle")
            </h3>
            <ul class="tech-list">
                <li>@LangApp.Get("CSharp")</li>
                <li>@LangApp.Get("AspNetCore")</li>
                <li>@LangApp.Get("ClientServer")</li>
                <li>@LangApp.Get("IndApps")</li>
                <li>@LangApp.Get("WPF")</li>
                <li>@LangApp.Get("HWInt")</li>
                <li>@LangApp.Get("RestAPI")</li>
                <li>@LangApp.Get("SQL")</li>
                <li>@LangApp.Get("Postgres")</li>
                <li>@LangApp.Get("Git")</li>
            </ul>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="glass-card scroll-reveal h-100 p-4">
            <h3 class="mb-3 text-neon">
                <i class="bi bi-rocket me-2"></i>@LangApp.Get("SolutionsTitle")
            </h3>
            <ul class="tech-list">
                <li>@LangApp.Get("CTPAT")</li>
                <li>@LangApp.Get("ZPL")</li>
                <li>@LangApp.Get("ITInv")</li>
            </ul>
        </div>
    </div>
</div>

<!-- Logros y participaciones -->
<div class="row mt-5">
    <div class="col-12 text-center">
        <h4><i class="bi bi-trophy"></i> @LangApp.Get("CareerAndAchievements")</h4>
        <hr />
    </div>

    <div class="col-md-6">
        <p><strong>@LangApp.Get("RoboticsSkills"):</strong></p>
        <ul class="list-unstyled">
            <li>
                <i class="bi bi-trophy-fill text-warning me-2"></i>
                <strong>@LangApp.Get("RobotBattle2018"):</strong>
                @LangApp.Get("ParticipationWithTeamDynamo")
            </li>
            <li>
                <i class="bi bi-trophy-fill text-warning me-2"></i>
                <strong>@LangApp.Get("RobotCIM"):</strong>
                @LangApp.Get("ParticipationWithTeamDynamoInCategories")
            </li>
            <li>
                <i class="bi bi-trophy-fill text-warning me-2"></i>
                <strong>@LangApp.Get("StateRoboticsNL"):</strong>
                @LangApp.Get("FirstAndSecondPlaceInSumoAndMinisumo")
            </li>
        </ul>
    </div>

    <div class="col-md-6">
        <p><strong>@LangApp.Get("TechnologicalInnovation"):</strong></p>
        <ul class="list-unstyled">
            <li>
                <i class="bi bi-award-fill text-warning me-2"></i>
                @LangApp.Get("ParticipationScienceFair2019")
            </li>
            <li>
                <i class="bi bi-award-fill text-warning me-2"></i>
                @LangApp.Get("ParticipationScienceFair2020")
            </li>
        </ul>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        LangApp.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        LangApp.OnLanguageChanged -= StateHasChanged;
    }
}
