@page "/projects"
@inject EdgarJairVazquezVillarreal.Services.LanguageService LangApp
@implements IDisposable

<PageTitle>@LangApp.Get("ProjectsTitle")</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">@LangApp.Get("ProjectsTitle")</h2>

    <div class="row">

        <!-- ── EsmeraldaPoint ─────────────────────────────────────────── -->
        <div class="col-12 mb-4">
            <div class="card shadow-sm project-card scroll-reveal">
                <div class="row g-0">
                    <div class="col-md-4 d-flex align-items-center justify-content-center p-4 border-end">
                        <div class="text-center">
                            <i class="bi bi-shop text-success" style="font-size: 4rem;"></i>
                            <h4 class="mt-3 text-neon fw-bold">EsmeraldaPoint</h4>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold">@LangApp.Get("ProjEsmeraldaSubtitle")</h5>
                            <p class="card-text mb-3">@LangApp.Get("ProjEsmeraldaDesc")</p>
                            <div class="d-flex flex-wrap gap-2 mb-4">
                                <span class="badge badge-glass">ASP.NET Core 10</span>
                                <span class="badge badge-glass">Blazor</span>
                                <span class="badge badge-glass">WPF</span>
                                <span class="badge badge-glass">PostgreSQL</span>
                                <span class="badge badge-glass">EF Core 10</span>
                            </div>
                            <div class="d-flex justify-content-end">
                                <a href="docs/esmeraldapoint" class="btn btn-outline-primary">
                                    <i class="bi bi-journal-text me-2"></i>@LangApp.Get("ViewDocs")
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── App de Gestión Empresarial ────────────────────────────── -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm project-card scroll-reveal">
                <div class="card-img-top d-flex align-items-center justify-content-center"
                     style="height: 200px; background-color: rgba(99,102,241,0.06);">
                    <i class="bi bi-laptop fs-1 text-primary"></i>
                </div>
                <div class="card-body">
                    <h5 class="card-title">@LangApp.Get("ProjMgmtTitle")</h5>
                    <p class="card-text">@LangApp.Get("ProjMgmtDesc")</p>
                    <ul class="small">
                        <li>@LangApp.Get("ProjMgmtB1")</li>
                        <li>@LangApp.Get("ProjMgmtB2")</li>
                    </ul>
                    <div class="mt-2 mb-3">
                        <span class="badge badge-glass">.NET 10</span>
                        <span class="badge badge-glass">Blazor</span>
                        <span class="badge badge-glass">SQL Server</span>
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-disabled-elegance btn-sm">
                            <i class="bi bi-file-earmark-text me-2"></i>@LangApp.Get("DocsPending")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Controlador de Hardware Industrial ─────────────────────── -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm project-card scroll-reveal">
                <div class="card-img-top d-flex align-items-center justify-content-center"
                     style="height: 200px; overflow: hidden;">
                    <img src="ImagenesDocs/Tarjeta de control 1 diseño.png"
                         class="h-100 object-fit-cover w-100"
                         alt="Diseño Tarjeta de Control" />
                </div>
                <div class="card-body">
                    <h5 class="card-title">@LangApp.Get("ProjHardwareTitle")</h5>
                    <p class="card-text">@LangApp.Get("ProjHardwareDesc")</p>
                    <ul class="small">
                        <li>@LangApp.Get("ProjHardwareB1")</li>
                        <li>@LangApp.Get("ProjHardwareB2")</li>
                    </ul>
                    <div class="mt-2 mb-3">
                        <span class="badge badge-glass">ESP32-S3</span>
                        <span class="badge badge-glass">SolidWorks</span>
                        <span class="badge badge-glass">Hardware</span>
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-disabled-elegance btn-sm">
                            <i class="bi bi-file-earmark-text me-2"></i>@LangApp.Get("DocsPending")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Sistema de Etiquetado ZPL ──────────────────────────────── -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm project-card scroll-reveal">
                <div class="card-img-top d-flex align-items-center justify-content-center"
                     style="height: 200px; background-color: rgba(99,102,241,0.06);">
                    <i class="bi bi-printer fs-1 text-secondary"></i>
                </div>
                <div class="card-body">
                    <h5 class="card-title">@LangApp.Get("ProjZPLTitle")</h5>
                    <p class="card-text">@LangApp.Get("ProjZPLDesc")</p>
                    <ul class="small">
                        <li>@LangApp.Get("ProjZPLB1")</li>
                        <li>@LangApp.Get("ProjZPLB2")</li>
                    </ul>
                    <div class="mt-2 mb-3">
                        <span class="badge badge-glass">C#</span>
                        <span class="badge badge-glass">ZPL</span>
                        <span class="badge badge-glass">Logística</span>
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-disabled-elegance btn-sm">
                            <i class="bi bi-file-earmark-text me-2"></i>@LangApp.Get("DocsPending")
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /row proyectos principales -->


    <!-- ── Proyectos Académicos ───────────────────────────────────────── -->
    <div class="row mt-4">
        <div class="col-12">
            <h3 class="mb-3 border-bottom pb-2" style="border-color: var(--accent-color) !important; color: var(--text-secondary);">
                @LangApp.Get("ProjAcademicTitle")
            </h3>
        </div>

        <!-- Brazo Robótico -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm project-card scroll-reveal">
                <div class="card-img-top d-flex align-items-center justify-content-center"
                     style="height: 180px; overflow: hidden;">
                    <img src="ImagenesDocs/Robotde6ejes.png"
                         class="h-100 w-100" style="object-fit: contain;"
                         alt="Brazo Robótico de 6 Ejes" />
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold">@LangApp.Get("ProjRobotArmTitle")</h5>
                        <i class="bi bi-gear-wide-connected fs-4" style="color: var(--text-secondary);"></i>
                    </div>
                    <p class="card-text">@LangApp.Get("ProjRobotArmDesc")</p>
                    <div class="mt-3 mb-3">
                        <span class="badge badge-glass">Diseño CAD 3D</span>
                        <span class="badge badge-glass">Arduino/C++</span>
                        <span class="badge badge-glass">Mecánica</span>
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-disabled-elegance btn-sm">
                            <i class="bi bi-file-earmark-text me-2"></i>@LangApp.Get("DocsPending")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sorteador de Obstáculos -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm project-card scroll-reveal">
                <div class="card-img-top d-flex align-items-center justify-content-center"
                     style="height: 200px; overflow: hidden;">
                    <img src="ImagenesDocs/Diseño sorteador de obstaculos.png"
                         class="h-100 w-100 object-fit-cover"
                         alt="Diseño Sorteador de Obstáculos" />
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold">@LangApp.Get("ProjObstacleTitle")</h5>
                        <i class="bi bi-car-front-fill text-primary fs-4"></i>
                    </div>
                    <p class="card-text">@LangApp.Get("ProjObstacleDesc")</p>
                    <div class="mt-3 mb-3">
                        <span class="badge badge-glass">Control PID</span>
                        <span class="badge badge-glass">Ultrasonido</span>
                        <span class="badge badge-glass">Embebido</span>
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-disabled-elegance btn-sm">
                            <i class="bi bi-file-earmark-text me-2"></i>@LangApp.Get("DocsPending")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Péndulo Invertido -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm project-card scroll-reveal">
                <div class="card-img-top d-flex align-items-center justify-content-center"
                     style="height: 200px; overflow: hidden;">
                    <img src="ImagenesDocs/Balancin.png"
                         class="h-100 w-100 object-fit-cover"
                         alt="Péndulo Invertido" />
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold">@LangApp.Get("ProjPendulumTitle")</h5>
                        <i class="bi bi-activity text-danger fs-4"></i>
                    </div>
                    <p class="card-text">@LangApp.Get("ProjPendulumDesc")</p>
                    <div class="mt-3 mb-3">
                        <span class="badge badge-glass">Control Moderno</span>
                        <span class="badge badge-glass">Modelado Dinámico</span>
                        <span class="badge badge-glass">Actuadores</span>
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-disabled-elegance btn-sm">
                            <i class="bi bi-file-earmark-text me-2"></i>@LangApp.Get("DocsPending")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Control de Flujos -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm project-card scroll-reveal">
                <div class="card-img-top d-flex align-items-center justify-content-center"
                     style="height: 180px; background-color: rgba(99,102,241,0.06);">
                    <i class="bi bi-water fs-1 text-secondary"></i>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold">@LangApp.Get("ProjFlowTitle")</h5>
                        <i class="bi bi-droplet-half text-info fs-4"></i>
                    </div>
                    <p class="card-text">@LangApp.Get("ProjFlowDesc")</p>
                    <div class="mt-3 mb-3">
                        <span class="badge badge-glass">Instrumentación</span>
                        <span class="badge badge-glass">Lazos de Control</span>
                        <span class="badge badge-glass">Automatización</span>
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-disabled-elegance btn-sm">
                            <i class="bi bi-file-earmark-text me-2"></i>@LangApp.Get("DocsPending")
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /row académicos -->
</div>

@code {
    protected override void OnInitialized()
    {
        LangApp.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        LangApp.OnLanguageChanged -= StateHasChanged;
    }
}
